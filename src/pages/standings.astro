---
import Layout from '../layouts/Layout.astro';
import StandingsTable from '../components/StandingsTable';
import { items } from '@wix/data';

const STATIC_TEAMS = [
  { pos: 1, name: "Northern Quarter Logistics", div: "PRM", p: 12, w: 10, d: 1, l: 1, gf: 34, ga: 12, gd: "+22", pts: 31, leader: true },
  { pos: 2, name: "Deansgate Audit FC",          div: "PRM", p: 12, w:  9, d: 2, l: 1, gf: 28, ga: 14, gd: "+14", pts: 29 },
  { pos: 3, name: "Spinningfields Utd",           div: "PRM", p: 12, w:  8, d: 1, l: 3, gf: 25, ga: 18, gd: "+7",  pts: 25 },
  { pos: 4, name: "Piccadilly Planners",          div: "PRM", p: 12, w:  6, d: 3, l: 3, gf: 19, ga: 15, gd: "+4",  pts: 21 },
  { pos: 5, name: "Media City Rovers",            div: "PRM", p: 12, w:  5, d: 2, l: 5, gf: 16, ga: 19, gd: "-3",  pts: 17 },
  { pos: 6, name: "Castlefield United",           div: "PRM", p: 12, w:  4, d: 2, l: 6, gf: 14, ga: 22, gd: "-8",  pts: 14 },
  { pos: 7, name: "Oxford Road Wanderers",        div: "PRM", p: 12, w:  3, d: 1, l: 8, gf: 12, ga: 25, gd: "-13", pts: 10, relegation: true },
  { pos: 8, name: "Ancoats Creative",             div: "PRM", p: 12, w:  2, d: 2, l: 8, gf: 10, ga: 28, gd: "-18", pts: 8,  relegation: true },
];

type Team = {
  pos: number; name: string; div: string; p: number; w: number; d: number;
  l: number; gf: number; ga: number; gd: string; pts: number;
  leader?: boolean; relegation?: boolean;
};

async function fetchTeams(): Promise<Team[]> {
  try {
    const result = await items.query('Teams').ascending('pos').find();
    if (!result.items.length) return STATIC_TEAMS;
    return result.items.map((raw) => {
      const r = raw as Record<string, unknown>;
      return {
        pos:        Number(r.pos)        || 0,
        name:       String(r.name        ?? ''),
        div:        String(r.division    ?? 'PRM'),
        p:          Number(r.p)          || 0,
        w:          Number(r.w)          || 0,
        d:          Number(r.d)          || 0,
        l:          Number(r.l)          || 0,
        gf:         Number(r.gf)         || 0,
        ga:         Number(r.ga)         || 0,
        gd:         String(r.gd         ?? '0'),
        pts:        Number(r.pts)        || 0,
        leader:     Boolean(r.leader),
        relegation: Boolean(r.relegation),
      };
    });
  } catch {
    return STATIC_TEAMS;
  }
}

const teams = await fetchTeams();

---

<Layout title="Standings" description="Corporate Athletic Division league table. Season standings updated after every match.">

  <section class="border-b border-border">
    <div class="max-w-7xl mx-auto px-4 py-10">
      <h1 class="font-display text-5xl md:text-7xl uppercase leading-none">Corporate Athletic Division</h1>
      <p class="font-body text-sm text-muted mt-3">Official standings. All discrepancies reported to the 4th official.</p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-10">
    <div class="flex items-center justify-between flex-wrap gap-4 mb-6">
      <div class="flex gap-0">
        {["Premier", "Championship", "League One"].map((d, i) => (
          <button
            class={`font-mono text-xs uppercase tracking-widest px-4 py-2 border border-border ${i === 0 ? "bg-dark text-on-dark" : "text-muted hover:bg-surface"} transition-colors`}
          >
            {d}
          </button>
        ))}
      </div>
      <p class="font-mono text-xs uppercase tracking-widest text-muted">Season: <strong class="text-text">Autumn 2026</strong></p>
    </div>

    <StandingsTable client:visible teams={teams} />

    <div class="mt-4 flex flex-wrap gap-6 font-mono text-xs uppercase tracking-widest text-muted">
      <span class="flex items-center gap-2"><span class="w-3 h-3 bg-primary inline-block" aria-hidden="true"></span> League Leaders</span>
      <span class="flex items-center gap-2"><span class="w-3 h-3 bg-red-600 inline-block" aria-hidden="true"></span> Relegation Zone</span>
      <span class="ml-auto hidden md:block">Tie-breakers: 1. Goal difference &nbsp; 2. Goals scored &nbsp; 3. Head-to-head</span>
    </div>
  </section>
</Layout>
